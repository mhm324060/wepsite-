<svg width="80" height="80" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="basicGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#4FD1C5"></stop>
      <stop offset="100%" stop-color="#2C7A7B"></stop>
    </linearGradient>
  </defs>

  <!-- background circle -->
  <circle cx="32" cy="32" r="30" fill="url(#basicGradient)" opacity="0.15"></circle>

  <!-- paw icon -->
  <circle cx="22" cy="24" r="4" fill="#38B2AC"></circle>
  <circle cx="32" cy="20" r="4" fill="#38B2AC"></circle>
  <circle cx="42" cy="24" r="4" fill="#38B2AC"></circle>
  <circle cx="28" cy="32" r="5" fill="#38B2AC"></circle>
  <circle cx="36" cy="32" r="5" fill="#38B2AC"></circle>

  <!-- house outline -->
  <path d="M16 36 L32 24 L48 36 V48 H16 Z" fill="none" stroke="#38B2AC" stroke-width="2" stroke-linejoin="round"></path>
</svg>