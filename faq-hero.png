  <circle cx="32" cy="22" r="2" fill="#FFF3C4"></circle>
  <circle cx="42" cy="24" r="2" fill="#FFF3C4"></circle>

  <!-- paw -->
  <circle cx="24" cy="46" r="3" fill="#D4AF37"></circle>
  <circle cx="32" cy="44" r="3" fill="#D4AF37"></circle>
  <circle cx="40" cy="46" r="3" fill="#D4AF37"></circle>
  <circle cx="28" cy="52" r="4" fill="#D4AF37"></circle>
  <circle cx="36" cy="52" r="4" fill="#D4AF37"></circle>

</svg>